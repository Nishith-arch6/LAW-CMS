# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legal_cms

# JWT
SECRET_KEY=change-me-to-a-random-secret-key-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# SMTP (optional — reminders via email)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@legalcms.local

# App
APP_NAME=Legal CMS
DEBUG=true

# Environment: dev | staging | prod
ENVIRONMENT=dev

# CORS — comma-separated origins or "*" for all
CORS_ORIGINS=*

# S3 / Cloud Storage (optional — production file uploads)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_ENDPOINT=
